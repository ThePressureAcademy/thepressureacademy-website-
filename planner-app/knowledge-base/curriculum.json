  "mentalHealth": [
    {
      "category": "Stress Management",
      "techniques": [
        {
          "name": "Box Breathing (4-4-4-4)",
          "desc": "Inhale 4s → Hold 4s → Exhale 4s → Hold 4s. 4 rounds. Activates parasympathetic.",
          "when": "Pre-shift, pre-comp, high-stress, can't sleep"
        },
        {
          "name": "5-4-3-2-1 Grounding",
          "desc": "5 see, 4 hear, 3 touch, 2 smell, 1 taste. Breaks anxiety spiral.",
          "when": "Anxiety, racing thoughts, overwhelm"
        },
        {
          "name": "Progressive Muscle Relaxation",
          "desc": "Tense 5s, release 10s. Toes to head. Deep relaxation response.",
          "when": "Before sleep, after shift, chronic tension"
        },
        {
          "name": "Cognitive Reframing",
          "desc": "Identify thought → Question it → Reframe to accurate version. Not positive — ACCURATE.",
          "when": "Negative self-talk, catastrophizing"
        }
      ]
    },
    {
      "category": "Sleep Optimization",
      "techniques": [
        {
          "name": "Sleep Hygiene Protocol (Shift Workers)",
          "desc": "Blackout curtains + 16-18°C + white noise. No screens 30min. Casein + magnesium.",
          "when": "Night shift recovery, broken sleep"
        },
        {
          "name": "Sleep Restriction Therapy",
          "desc": "Restrict bed time to actual sleep time. Increase by 15min when 85%+ efficiency.",
          "when": "Chronic insomnia, lying awake"
        },
        {
          "name": "Nap Strategy",
          "desc": "20min power nap OR 90min full cycle. Never 40-60min (grogginess).",
          "when": "Pre-night-shift, mid-day recovery"
        }
      ]
    },
    {
      "category": "Competition Mindset",
      "techniques": [
        {
          "name": "Pre-Competition Visualization",
          "desc": "15min eyes closed. Walk to mat, grip fight, first techniques, adversity, winning. Include SENSORY detail.",
          "when": "Night before, morning of, warm-up"
        },
        {
          "name": "Process Goals vs Outcome Goals",
          "desc": "Set 'pull guard within 30s' not 'win gold.' Process focus reduces anxiety 40%.",
          "when": "Goal setting, pre-comp planning"
        },
        {
          "name": "Post-Loss Protocol",
          "desc": "1. Eat/hydrate 30min. 2. Acknowledge feeling. 3. Write 3 worked/3 improve (48hrs later). 4. Talk to coach.",
          "when": "After loss, bad training"
        }
      ]
