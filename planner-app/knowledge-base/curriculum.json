          "when": "Daily in Planner log"
        },
        {
          "name": "Values-Based Decision Making",
          "desc": "Top 5 values. Score each option against values. Highest = answer.",
          "when": "Major decisions, conflicts"
        },
        {
          "name": "Mindful Mat Time",
          "desc": "First 5min: breathing and movement only. No technique goals. Feel the mat.",
          "when": "Start of every session"
